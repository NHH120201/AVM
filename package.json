{
  "name": "animal-video-maker",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -w --project tsconfig.main.json",
    "dev:renderer": "vite build --watch",
    "dev:electron": "wait-on dist/renderer/index.html && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "set VITE_DEV_SERVER_URL=http://localhost:5173 && electron .",
    "dist": "npm run build && electron-builder",
    "make-video": "npm run build:main && node dist/main/cli.js"
  },
  "build": {
    "appId": "com.animalkingdom.videomaker",
    "productName": "Animal Video Maker",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4"
  }
}
